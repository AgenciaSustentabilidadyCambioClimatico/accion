# Copiar a application.yml (Figaro), secrets del host o variables del PaaS.
# Producción: obligatorias salvo que use solo almacenamiento local (no recomendado).

AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCESS_KEY=
AZURE_STORAGE_CONTAINER=

# Opcional: AzureCloud (por defecto), AzureChinaCloud, AzureUSGovernment, AzureGermanCloud
# AZURE_STORAGE_ENVIRONMENT=AzureCloud

# true = URLs públicas sin SAS (el contenedor debe permitir lectura anónima)
# AZURE_STORAGE_PUBLIC_CONTAINER=false

# Segundos de validez de URL firmada (equivalente al antiguo aws_authenticated_url_expiration)
# AZURE_STORAGE_URL_EXPIRY=1800

# Desarrollo: usar Blob real en lugar de disco local
# AZURE_STORAGE_USE_IN_DEV=false
